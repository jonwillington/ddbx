{
  "name": "vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev --remote",
    "dev:all": "npm-run-all -p dev dev:worker",
    "build": "tsc && vite build",
    "lint": "eslint --fix",
    "preview": "vite preview",
    "worker:deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute director-dealings --remote --file=worker/db/schema.sql",
    "db:init:local": "wrangler d1 execute director-dealings --local --file=worker/db/schema.sql",
    "pipeline:run": "curl -X POST http://localhost:8787/__cron/run"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@heroui/react": "3.0.1",
    "@heroui/styles": "3.0.1",
    "clsx": "2.1.1",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250401.0",
    "@eslint/compat": "1.2.8",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.25.1",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/vite": "4.1.11",
    "@types/node": "20.5.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "8.31.1",
    "@typescript-eslint/parser": "8.31.1",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.25.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-unused-imports": "4.1.4",
    "globals": "16.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "8.5.6",
    "prettier": "3.5.3",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.1.11",
    "typescript": "5.6.3",
    "vite": "6.0.11",
    "vite-tsconfig-paths": "5.1.4",
    "wrangler": "^4.0.0"
  }
}
